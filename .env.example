# Move this file to ".env" and set your own values to use a real store.
# The variables added in this file are only available locally
# Run "netlify env:import .env" to import them to your Netlify site

# Use these values for a demo store
PUBLIC_STORE_DOMAIN="mock.shop"
SESSION_SECRET="mock secret"

# PUBLIC_STOREFRONT_API_TOKEN=""
# PRIVATE_STOREFRONT_API_TOKEN=""
# PUBLIC_STOREFRONT_ID=""

# --- Daily Finance News (LINE配信) ---
# NewsAPI.org の API キー: https://newsapi.org/register
NEWS_API_KEY=""

# Anthropic Claude API キー: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# LINE Messaging API チャネルアクセストークン
# LINE Developers Console で取得: https://developers.line.biz/
LINE_CHANNEL_ACCESS_TOKEN=""

# 送信先の LINE ユーザーID または グループID
# ユーザーIDは LINE Developers の Webhook イベントの "userId" から取得
LINE_USER_ID=""